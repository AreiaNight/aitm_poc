<%# Título de la página para ser usado por el layout %>
<% @title = "Future Industries — Login" %>

<div class="login-container">
  <div class="login-box">

    <%# Encabezado del formulario de login %>
    <div class="login-header">
      <h1>Welcome to Future Industries</h1>
      <p class="subtitle">Where we build the future</p>
    </div>

    <%# Si la variable `@error` está presente, mostramos el mensaje de error al usuario %>
    <% if @error %>
      <div class="alert-error">
        <p><%= @error %></p>
      </div>
    <% end %>

    <%# Formulario que envía `POST /login` con `email` y `password` %>
    <form action="/login" method="post">

      <div class="form-group">
        <label for="email">E-mail address</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="Enter your email"
          required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Your password"
          required>
      </div>

      <%# Botón que envía el formulario al servidor %>
      <button type="submit" class="btn-primary">
        Login
      </button>

    </form>

    <%# Credenciales de prueba incluidas para facilitar la demostración del PoC %>
    <div class="hint">
      <p><strong>Test Credentials</strong></p>
      <p>avatarkyoshi@futureindustries.com / rangiIsTheBestGirlfriend</p>
      <p>avatarkorra@futureindustries.com / iloveAsamiSato<3</p>
      <p>avataryangchen@futureindustries.com / yangchenRules</p>
    </div>

  </div>
</div>